# Copy to `.env` (gitignored). The only real secret this system reads is the LLM provider key, and
# only when the live model adapter is explicitly enabled. Everything else is mocked or sandboxed.

# --- Live model adapter (optional; OFF by default) ---
# Read at runtime only when a model config selects the live adapter AND --allow-live-model is passed.
# Never commit a real value; the credential scanner fails if a key-shaped value is committed.
ANTHROPIC_API_KEY=

# --- Operational bulletin selection (optional) ---
# Path to the bulletin to load. Prefer the CLI flag:
#   python scripts/run.py --workflow ops_summary --bulletin data/bulletins/routine.json
# This env var is a fallback. The code path is identical regardless of which file is selected; only
# validated field content can move posture, and only ever upward. Unset => data/operational_bulletin.json.
OPERATIONAL_BULLETIN_PATH=

# --- Admin/status surface ---
# Authorization token for admin_guard. The guard fails CLOSED when this is unset. Set it only if you
# need to exercise an allowed admin intent.
ADMIN_TOKEN=

# CORS allowlist for the status surface (orchestrator/app.py). Comma-separated origins; no wildcard,
# credentials disabled. Unset => http://localhost:3000.
CORS_ALLOW_ORIGINS=
