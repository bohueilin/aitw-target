# ─── Secrets & local-only config (NEVER commit) ───────────────────────────────
# The LLM provider key is the one allowed real secret; it lives in .env (runtime env).
.env
.env.*
!.env.example

# Local-only pattern file for the credential guard (optional). The committed counterpart is
# secret_guard_local.example.yaml, which ships with placeholder patterns only.
secret_guard_local.yaml

# ─── Runtime artifacts ────────────────────────────────────────────────────────
# Agent workspaces and observation-log run outputs are regenerated, not tracked.
workspaces/
runs/
*.run.jsonl

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env.venv/

# ─── Tooling / OS ─────────────────────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.DS_Store
.hypothesis/
